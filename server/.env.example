NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_this_with_a_random_64_char_string
AUTH_MODE=local
DB_ADAPTER=sqlite
SQLITE_PATH=./data/inspection.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
ADMIN_PASSWORD=changeme

# ── Injector flow test bench integration (Admin → Injector Tests) ────────────
# Get the key from the bench vendor's web portal: Profile → "Generate New"
# under API KEY. Leave unset to disable sync entirely (no admin tab errors,
# just an inactive feature).
INJECTOR_API_KEY=
INJECTOR_API_BASE_URL=https://cloudx.carbonzapp.com/userapi/v1/client/getReports
# Auth header name/scheme were not specified by the vendor doc we had —
# defaults to a standard "Authorization: Bearer <key>" header. The key is
# also sent as an `api_key` body field as a fallback. Adjust if the vendor's
# real scheme differs once you've confirmed it against a live response.
INJECTOR_API_AUTH_HEADER=Authorization
INJECTOR_API_AUTH_SCHEME=Bearer
# How far back to look on the very first sync (before a cursor exists).
INJECTOR_SYNC_INITIAL_LOOKBACK_DAYS=30
# How often to auto-poll for new reports, in minutes (in addition to the
# "Sync Now" button in Admin → Injector Tests).
INJECTOR_SYNC_INTERVAL_MINUTES=15

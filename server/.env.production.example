# ─────────────────────────────────────────────────────────────────────────────
# PDI Inspection App — Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to server/.env and fill in the values before deploying.
# NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Node environment — must be "production"
NODE_ENV=production

# Port the Express server listens on.
# If running behind IIS with URL Rewrite, this can remain 3001.
PORT=3001

# The public URL where the app is accessed by users.
# Must exactly match a Redirect URI registered in your Azure app registration.
# Example: https://inspection.yourcompany.com
CLIENT_URL=https://inspection.yourcompany.com

# ── Authentication: Microsoft Entra ID ───────────────────────────────────────
# From portal.azure.com → Entra ID → App registrations → your app → Overview
ENTRA_TENANT_ID=your-directory-tenant-id
ENTRA_CLIENT_ID=your-application-client-id

# ── JWT (internal app tokens) ─────────────────────────────────────────────────
# Generate a strong random secret — e.g. in PowerShell:
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Maximum 256 }))
# Keep this secret. Changing it will invalidate all active sessions.
JWT_SECRET=replace-with-a-long-random-string-at-least-48-characters

# ── Database ──────────────────────────────────────────────────────────────────
DB_ADAPTER=sqlite

# Use an absolute path so the database location doesn't depend on the working
# directory. Create this directory before first run.
# Example: C:\PDIApp\data\inspection.db
SQLITE_PATH=C:\PDIApp\data\inspection.db

# ── File uploads ──────────────────────────────────────────────────────────────
# Absolute path to the uploads folder. Must be writable by the process account.
UPLOAD_DIR=C:\PDIApp\uploads
MAX_FILE_SIZE_MB=25
